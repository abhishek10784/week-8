#include <stdio.h>
int isPrime(int n) {
int i;
if (n < 2) return 0;
for (i = 2; i * i <= n; i++)
if (n % i == 0) return 0;
return 1;
}
int main() {
int n;
printf("25331A05H2");
printf("\nEnter a number: ");
scanf("%d", &n);
if (isPrime(n))
printf("%d is Prime\n", n);
else
printf("%d is NOT Prime\n", n);
return 0;
}
